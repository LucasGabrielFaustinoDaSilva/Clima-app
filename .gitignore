# Build Folders (the binaries are usually not needed)
bin/
obj/

# Visual Studio cache files
.vs/

# Rider cache files
.idea/

# User-specific files
*.suo
*.user
*.userprefs

# Build results
[Dd]ebug/
[Rr]elease/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of this
**/packages/*

# Visual Studio Code workspace specific files
.vscode/

# Azure Web App publish folder
publish/

# Miscellaneous
*.db
*.log
